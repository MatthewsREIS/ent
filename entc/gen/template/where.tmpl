{{/* gotype: entgo.io/ent/entc/gen.Type */}}

{{ define "where" }}

{{- /* $isSQL gates the compact entbuilder-routed predicate emission. Gremlin and
      other non-SQL dialects keep their original multi-line form because the
      entbuilder helpers only wrap sql.Field* functions. */ -}}
{{ $isSQL := eq $.Storage.Name "sql" }}

{{- with extend $ "Package" $.Package -}}
	{{ template "header" . }}
{{ end }}

{{- /* Wrap the import template with a scope flag that triggers the entbuilder import
      for the compact predicate helpers used below (SQL storage only). */ -}}
{{ if $isSQL }}
	{{ with extend $ "WhereUsesEntbuilder" true }}
		{{ template "import" . }}
	{{ end }}
{{ else }}
	{{ template "import" $ }}
{{ end }}

{{ if .HasOneFieldID }}
	{{- if $isSQL }}
		{{- /* ID equality (compact — no value scanner, no go-type conversion). */}}
		// ID filters vertices based on their ID field.
		func ID(id {{ $.ID.Type }}) predicate.{{ $.Name }} { return entbuilder.FieldEQ[predicate.{{ $.Name }}]({{ $.ID.Constant }}, id) }

		{{ range $op := $.ID.Ops }}
			{{- $arg := "id" }}{{ if $op.Variadic }}{{ $arg = "ids" }}{{ end }}
			{{- $func := printf "ID%s" $op.Name }}
			{{- $opCode := call $.Storage.OpCode $op }}
			// {{ $func }} applies the {{ $op.Name }} predicate on the ID field.
			{{- if $op.Variadic }}
				{{- /* In / NotIn: variadic slice doesn't fit entbuilder.FieldIn signature cleanly;
				      emit the direct 1-line sql.Field<Op> form. */}}
				func {{ $func }}({{ $arg }} ...{{ $.ID.Type }}) predicate.{{ $.Name }} { return predicate.{{ $.Name }}(sql.Field{{ $opCode }}({{ $.ID.Constant }}, {{ $arg }}...)) }
			{{- else if $op.Niladic }}
				func {{ $func }}() predicate.{{ $.Name }} { return entbuilder.Field{{ $opCode }}[predicate.{{ $.Name }}]({{ $.ID.Constant }}) }
			{{- else }}
				func {{ $func }}({{ $arg }} {{ $.ID.Type }}) predicate.{{ $.Name }} { return entbuilder.Field{{ $opCode }}[predicate.{{ $.Name }}]({{ $.ID.Constant }}, {{ $arg }}) }
			{{- end }}
		{{ end }}
	{{- else }}
		{{- /* Non-SQL (e.g. gremlin) — keep the original multi-line emission. */}}
		// ID filters vertices based on their ID field.
		func ID(id {{ $.ID.Type }}) predicate.{{ $.Name }} {
			return predicate.{{ $.Name }}(
				{{- $tmpl := printf "dialect/%s/predicate/id" $.Storage }}
				{{- xtemplate $tmpl $ -}}
			)
		}

		{{ range $op := $.ID.Ops }}
			{{ $arg := "id" }}{{ if $op.Variadic }}{{ $arg = "ids" }}{{ end }}
			{{ $func := printf "ID%s" $op.Name }}
			// {{ $func }} applies the {{ $op.Name }} predicate on the ID field.
			func {{ $func }}({{ $arg }} {{ if $op.Variadic }}...{{ end }}{{ $.ID.Type }}) predicate.{{ $.Name }} {
				return predicate.{{ $.Name }}(
					{{- with extend $ "Arg" $arg "Op" $op "Storage" $.Storage -}}
						{{ $tmpl := printf "dialect/%s/predicate/id/ops" $.Storage }}
						{{- xtemplate $tmpl . }}
					{{- end -}}
				)
			}
		{{ end }}
	{{- end }}
{{ end }}

{{ range $f := $.Fields }}
	{{ $func := $f.StructField }}
	{{/* JSON cannot be compared using "=" and Enum has a type defined with the field name */}}
	{{ $hasP := not (or $f.IsJSON $f.IsEnum) }}
	{{ $comparable := or $f.ConvertedToBasic $f.Type.Valuer }}
	{{ $undeclared := (and (ne $func "Label") (ne $func "OrderOption") (ne $func "Hooks") (ne $func "Policy") (ne $func "Table") (ne $func "FieldID") (ne $func "Value") (ne $func $.Name)) }}
	{{- if and $hasP $comparable $undeclared }}
		{{ $arg := "v" }}
		// {{ $func }} applies equality check predicate on the {{ quote $f.Name }} field. It's identical to {{ $func }}EQ.
		{{- if $f.HasValueScanner }}
			func {{ $func }}({{ $arg }} {{ $f.Type }}) predicate.{{ $.Name }} {
				vc, err := ValueScanner.{{ $f.StructField }}.Value({{ $arg }})
				{{- $arg = "vc" }}
				return predicate.{{ $.Name }}OrErr(
					{{- with extend $ "Arg" $arg "Field" $f -}}
						{{ $tmpl := printf "dialect/%s/predicate/field" $.Storage }}
						{{- xtemplate $tmpl . }}
					{{- end }}, err)
			}
		{{- else if and $f.HasGoType (not $f.Type.Valuer) }}
			func {{ $func }}({{ $arg }} {{ $f.Type }}) predicate.{{ $.Name }} {
				vc := {{ $f.BasicType "v" }}
				{{- $arg = "vc" }}
				return predicate.{{ $.Name }}(
					{{- with extend $ "Arg" $arg "Field" $f -}}
						{{ $tmpl := printf "dialect/%s/predicate/field" $.Storage }}
						{{- xtemplate $tmpl . }}
					{{- end -}}
				)
			}
		{{- else if $isSQL }}
			{{- /* SQL simple path — compact 1-line body routed through entbuilder.FieldEQ. */}}
			func {{ $func }}({{ $arg }} {{ $f.Type }}) predicate.{{ $.Name }} { return entbuilder.FieldEQ[predicate.{{ $.Name }}]({{ $f.Constant }}, {{ $arg }}) }
		{{- else }}
			{{- /* Non-SQL fallback: preserve original multi-line emission. */}}
			func {{ $func }}({{ $arg }} {{ $f.Type }}) predicate.{{ $.Name }} {
				return predicate.{{ $.Name }}(
					{{- with extend $ "Arg" $arg "Field" $f -}}
						{{ $tmpl := printf "dialect/%s/predicate/field" $.Storage }}
						{{- xtemplate $tmpl . }}
					{{- end -}}
				)
			}
		{{- end }}
	{{- end }}
{{ end }}

{{ range $f := $.Fields }}
	{{ range $op := $f.Ops }}
		{{ $arg := "v" }}{{ if $op.Variadic }}{{ $arg = "vs" }}{{ end }}
		{{ $stringOp := eq $op.Name "EqualFold" "Contains" "ContainsFold" "HasPrefix" "HasSuffix" }}
		{{ $func := print $f.StructField $op.Name }}
		{{ $type := $f.Type.String }}{{ if $f.IsEnum }}{{ $type = trimPackage $type $.Package }}{{ end }}
		{{ $opCode := call $.Storage.OpCode $op }}
		// {{ $func }} applies the {{ $op.Name }} predicate on the {{ quote $f.Name }} field.
		{{- if and $f.HasValueScanner (or $op.Variadic (not $op.Niladic)) }}
			{{- /* Preserved multi-line value-scanner path. */}}
			func {{ $func }}({{ if not $op.Niladic }}{{ $arg }} {{ if $op.Variadic }}...{{ end }}{{ $type }}{{ end }}) predicate.{{ $.Name }} {
				{{- if $op.Variadic }}
					var (
						err error
						v = make([]any, len({{ $arg }}))
					)
					for i := range v {
						if v[i], err = ValueScanner.{{ $f.StructField }}.Value({{ print $arg "[i]" }}); err != nil {
							break
						}
					}
					{{- $arg = "v" }}
				{{- else }}
					vc, err := ValueScanner.{{ $f.StructField }}.Value({{ $arg }})
					{{- $arg = "vc" }}
					{{- if $stringOp }}
						{{- $arg = "vcs" }}
						vcs, ok := vc.(string)
						if err == nil && !ok {
							err = fmt.Errorf("{{ $f.Name }} value is not a string: %T", vc)
						}
					{{- end }}
				{{- end }}
				return predicate.{{ $.Name }}OrErr(
					{{- with extend $ "Arg" $arg "Field" $f "Op" $op "Storage" $.Storage -}}
						{{ $tmpl := printf "dialect/%s/predicate/field/ops" $.Storage }}
						{{- xtemplate $tmpl . }}
					{{- end }}, err)
			}
		{{- else if and $f.HasGoType (or $stringOp (not $f.Type.Valuer)) }}
			{{- /* Preserved multi-line go-type pre-conversion path. */}}
			func {{ $func }}({{ if not $op.Niladic }}{{ $arg }} {{ if $op.Variadic }}...{{ end }}{{ $type }}{{ end }}) predicate.{{ $.Name }} {
				{{- if $op.Variadic }}
					v := make([]any, len({{ $arg }}))
					for i := range v {
						v[i] = {{ $f.BasicType (printf "%s[i]" $arg) }}
					}
					{{- $arg = "v" }}
				{{- else if not $op.Niladic }}
					vc := {{ $f.BasicType "v" }}
					{{- $arg = "vc" }}
				{{- end }}
				return predicate.{{ $.Name }}(
					{{- with extend $ "Arg" $arg "Field" $f "Op" $op "Storage" $.Storage -}}
						{{ $tmpl := printf "dialect/%s/predicate/field/ops" $.Storage }}
						{{- xtemplate $tmpl . }}
					{{- end -}}
				)
			}
		{{- else if $isSQL }}
			{{- if $op.Variadic }}
				{{- /* SQL simple variadic path (In/NotIn): keep 1-line via direct sql.Field<Op>;
				      entbuilder.FieldIn signature doesn't fit typed variadic without a conversion. */}}
				func {{ $func }}({{ $arg }} ...{{ $type }}) predicate.{{ $.Name }} { return predicate.{{ $.Name }}(sql.Field{{ $opCode }}({{ $f.Constant }}, {{ $arg }}...)) }
			{{- else if $op.Niladic }}
				{{- /* SQL simple niladic (IsNull/NotNull): route through entbuilder.FieldIsNull/FieldNotNull. */}}
				func {{ $func }}() predicate.{{ $.Name }} { return entbuilder.Field{{ $opCode }}[predicate.{{ $.Name }}]({{ $f.Constant }}) }
			{{- else }}
				{{- /* SQL simple scalar path: route through entbuilder.Field<OpCode>. $opCode matches
				      the entbuilder helper name for EQ/NEQ/GT/GTE/LT/LTE/Contains/HasPrefix/HasSuffix/
				      EqualFold/ContainsFold. gofmt re-wraps lines >104 chars to a 3-line form. */}}
				func {{ $func }}({{ $arg }} {{ $type }}) predicate.{{ $.Name }} { return entbuilder.Field{{ $opCode }}[predicate.{{ $.Name }}]({{ $f.Constant }}, {{ $arg }}) }
			{{- end }}
		{{- else }}
			{{- /* Non-SQL fallback: preserve original multi-line emission. */}}
			func {{ $func }}({{ if not $op.Niladic }}{{ $arg }} {{ if $op.Variadic }}...{{ end }}{{ $type }}{{ end }}) predicate.{{ $.Name }} {
				return predicate.{{ $.Name }}(
					{{- with extend $ "Arg" $arg "Field" $f "Op" $op "Storage" $.Storage -}}
						{{ $tmpl := printf "dialect/%s/predicate/field/ops" $.Storage }}
						{{- xtemplate $tmpl . }}
					{{- end -}}
				)
			}
		{{- end }}
	{{ end }}
{{ end }}

{{ range $e := $.Edges }}
	{{ $func := print "Has" $e.StructField }}
	// {{ $func }} applies the HasEdge predicate on the {{ quote $e.Name }} edge.
	func {{ $func }}() predicate.{{ $.Name }} {
		return predicate.{{ $.Name }}(
			{{- with extend $ "Edge" $e -}}
				{{ $tmpl := printf "dialect/%s/predicate/edge/has" $.Storage }}
				{{- xtemplate $tmpl . }}
			{{- end -}}
		)
	}
	{{ $func = printf "%sWith" $func }}
	// {{ $func }} applies the HasEdge predicate on the {{ quote $e.Name }} edge with a given conditions (other predicates).
	func {{ $func }}(preds ...predicate.{{ $e.Type.Name }}) predicate.{{ $.Name }} {
		return predicate.{{ $.Name }}(
			{{- with extend $ "Edge" $e -}}
				{{ $tmpl := printf "dialect/%s/predicate/edge/haswith" $.Storage }}
				{{- xtemplate $tmpl . }}
			{{- end -}}
		)
	}
{{ end }}

{{ if $isSQL }}
	// And groups predicates with the AND operator between them.
	func And(predicates ...predicate.{{ $.Name }}) predicate.{{ $.Name }} { return entbuilder.AndPreds(predicates...) }

	// Or groups predicates with the OR operator between them.
	func Or(predicates ...predicate.{{ $.Name }}) predicate.{{ $.Name }} { return entbuilder.OrPreds(predicates...) }

	// Not applies the not operator on the given predicate.
	func Not(p predicate.{{ $.Name }}) predicate.{{ $.Name }} { return entbuilder.NotPred(p) }
{{ else }}
	// And groups predicates with the AND operator between them.
	func And(predicates ...predicate.{{ $.Name }}) predicate.{{ $.Name }} {
		return predicate.{{ $.Name }}(
			{{- $tmpl := printf "dialect/%s/predicate/and" $.Storage }}
			{{- xtemplate $tmpl . -}}
		)
	}

	// Or groups predicates with the OR operator between them.
	func Or(predicates ...predicate.{{ $.Name }}) predicate.{{ $.Name }} {
		return predicate.{{ $.Name }}(
			{{- $tmpl := printf "dialect/%s/predicate/or" $.Storage }}
			{{- xtemplate $tmpl . -}}
		)
	}

	// Not applies the not operator on the given predicate.
	func Not(p predicate.{{ $.Name }}) predicate.{{ $.Name }} {
		return predicate.{{ $.Name }}(
			{{- $tmpl := printf "dialect/%s/predicate/not" $.Storage }}
			{{- xtemplate $tmpl . -}}
		)
	}
{{ end }}

{{ template "where/additional" $ }}

{{ with $tmpls := matchTemplate "where/additional/*" }}
	{{ range $tmpl := $tmpls }}
		{{ xtemplate $tmpl $ }}
	{{ end }}
{{ end }}

{{ end }}

{{/* A template that can be overridden in order to add additional code for the type package. */}}
{{ define "where/additional" }}{{ end }}

{{/* gotype: entgo.io/ent/entc/gen.typeScope */}}

{{ define "dialect/sql/delete/fields" }}
    {{- with $tmpls := matchTemplate "dialect/sql/delete/fields/additional/*" }}
        {{- range $tmpl := $tmpls }}
            {{- xtemplate $tmpl $ }}
        {{- end }}
    {{- end }}
{{- end }}

{{ define "dialect/sql/delete" }}
{{ $builder := pascal $.Scope.Builder }}
{{ $receiver := $.Scope.Receiver }}
{{ $mutation := print $receiver ".mutation" }}
{{ $descriptor := printf "%sDeleteDescriptor" $.Package }}

var {{ $descriptor }} = entbuilder.DeleteDescriptor[config, *{{ $.MutationName }}]{
	Table: {{ $.Package }}.Table,
	{{- if $.HasOneFieldID }}
	ID: &entbuilder.DeleteIDDescriptor[*{{ $.MutationName }}]{
		Column: {{ $.Package }}.{{ $.ID.Constant }},
		Type:   field.{{ $.ID.Type.ConstName }},
		Value: func(m *{{ $.MutationName }}) (driver.Value, bool, error) {
			if id, ok := m.{{ $.ID.MutationGet }}(); ok {
				return id, true, nil
			}
			return nil, false, nil
		},
	},
	{{- end }}
	{{- with $tmpls := matchTemplate "dialect/sql/delete/descriptor/*" }}
		{{- range $tmpl := $tmpls }}
			{{- xtemplate $tmpl $ }}
		{{- end }}
	{{- end }}
	Predicates: func(m *{{ $.MutationName }}) []func(*sql.Selector) {
		predicates := make([]func(*sql.Selector), len(m.predicates))
		for i := range m.predicates {
			predicates[i] = m.predicates[i]
		}
		return predicates
	},
}

func ({{ $receiver}} *{{ $builder }}) sqlExec(ctx context.Context) (int, error) {
	_spec, err := entbuilder.BuildDeleteSpec({{ $receiver }}.config, {{ $mutation }}, &{{ $descriptor }})
	if err != nil {
		return 0, err
	}
	{{- /* Allow mutating the sqlgraph.DeleteSpec by ent extensions or user templates.*/}}
	{{- with $tmpls := matchTemplate "dialect/sql/delete/spec/*" }}
		{{- range $tmpl := $tmpls }}
			{{- xtemplate $tmpl $ }}
		{{- end }}
	{{- end }}
	affected, err := sqlgraph.DeleteNodes(ctx, {{ $receiver}}.driver, _spec)
	if err != nil && sqlgraph.IsConstraintError(err) {
		err = &ConstraintError{msg: err.Error(), wrap: err}
	}
	{{ $mutation }}.done = true
	return affected, err
}

{{ end }}

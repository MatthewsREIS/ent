{{ define "dialect/sql/create" }}
{{ $builder := pascal $.Scope.Builder }}
{{ $receiver := $.Scope.Receiver }}
{{ $mutation := print $receiver ".mutation" }}
{{ $descriptor := printf "%sCreateDescriptor" $.Package }}

var {{ $descriptor }} = entbuilder.CreateDescriptor[config, {{ $.Name }}, *{{ $.MutationName }}]{
	Table: {{ $.Package }}.Table,
	NewNode: func(cfg config) *{{ $.Name }} {
		return &{{ $.Name }}{config: cfg}
	},
{{- if and $.ID (not $.HasCompositeID) }}
	ID: {{ template "dialect/sql/create/descriptor/id" . }}
{{- end }}
{{- if $.MutationFields }}
	Fields: []entbuilder.FieldDescriptor[config, {{ $.Name }}, *{{ $.MutationName }}]{
{{- range $f := $.MutationFields }}
{{- with extend $ "Field" $f }}
		{{ template "dialect/sql/create/descriptor/field" . }}
{{- end }}
{{- end }}
	},
{{- end }}
{{- if $.EdgesWithID }}
	Edges: []entbuilder.EdgeDescriptor[config, {{ $.Name }}, *{{ $.MutationName }}]{
{{- range $e := $.EdgesWithID }}
{{- with extend $ "Edge" $e }}
		{{ template "dialect/sql/create/descriptor/edge" . }}
{{- end }}
{{- end }}
	},
{{- end }}
}

func ({{ $receiver }} *{{ $builder }}) sqlSave(ctx context.Context) (*{{ $.Name }}, error) {
    if err := entgen.CheckCreate({{ $receiver }}.driver.Dialect(), {{ $mutation }}, {{ index $.Scope "SpecVar" }}); err != nil {
        return nil, err
    }
    _node, _spec, err := entbuilder.BuildCreateSpec({{ $receiver }}.config, {{ $mutation }}, &{{ $descriptor }})
    if err != nil {
        return nil, err
    }
    {{- with $tmpls := matchTemplate "dialect/sql/create/spec/*" }}
        {{- range $tmpl := $tmpls }}
            {{- xtemplate $tmpl $ }}
        {{- end }}
    {{- end }}
    if err := sqlgraph.CreateNode(ctx, {{ $receiver }}.driver, _spec); err != nil {
        if sqlgraph.IsConstraintError(err) {
            err = &ConstraintError{msg: err.Error(), wrap: err}
        }
        return nil, err
    }
    if err := entbuilder.ApplyGeneratedID({{ $mutation }}, _spec, _node, &{{ $descriptor }}); err != nil {
        return nil, err
    }
    {{- if $.HasOneFieldID }}
        {{ $mutation }}.{{ $.ID.BuilderField }} = &_node.{{ $.ID.StructField }}
    {{- end }}
    {{ $mutation }}.done = true
    return _node, nil
}


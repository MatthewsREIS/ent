{{ define "dialect/sql/create/descriptor/id" }}
{{- $id := $.ID -}}
&entbuilder.IDDescriptor[config, {{ $.Name }}, *{{ $.MutationName }}]{
	Column: {{ $.Package }}.{{ $id.Constant }},
	Type: field.{{ $id.Type.ConstName }},
	UserDefined: {{ $id.UserDefined }},
{{- if $id.UserDefined }}
	Value: func(m *{{ $.MutationName }}) (entbuilder.FieldValue, bool, error) {
		if id, ok := m.{{ $id.MutationGet }}(); ok {
{{- if and $id.Type.ValueScanner (not $id.Type.RType.IsPtr) }}
			idCopy := id
			return entbuilder.FieldValue{Spec: &idCopy, Node: id}, true, nil
{{- else }}
			return entbuilder.FieldValue{Spec: id, Node: id}, true, nil
{{- end }}
		}
		return entbuilder.FieldValue{}, false, nil
	},
	AssignNode: func(node *{{ $.Name }}, fv entbuilder.FieldValue) error {
		node.ID = fv.Node.({{ $id.Type }})
		return nil
	},
{{- end }}
	AssignGenerated: func(node *{{ $.Name }}, value driver.Value) error {
{{- if $id.Type.ValueScanner }}
		switch v := value.(type) {
		case *{{ $id.Type }}:
			if v != nil {
				node.ID = *v
				return nil
			}
		case {{ $id.Type }}:
			node.ID = v
			return nil
		}
		if err := node.ID.Scan(value); err != nil {
			return err
		}
{{- else if not $id.Type.Numeric }}
		if v, ok := value.({{ $id.Type }}); ok {
			node.ID = v
			return nil
		}
		return fmt.Errorf("unexpected {{ $.Name }}.ID type: %T", value)
{{- else }}
		id := value.(int64)
		node.ID = {{ $id.Type }}(id)
{{- end }}
		return nil
	},
},
{{ end }}

{{ define "dialect/sql/create/descriptor/field" }}
{{- $f := $.Scope.Field -}}
{
	Column: {{ $.Package }}.{{ $f.Constant }},
	Type: field.{{ $f.Type.ConstName }},
	Value: func(m *{{ $.MutationName }}) (entbuilder.FieldValue, bool, error) {
		if value, ok := m.{{ $f.MutationGet }}(); ok {
{{- if $f.HasValueScanner }}
			vv, err := {{ $f.ValueFunc }}(value)
			if err != nil {
				return entbuilder.FieldValue{}, false, err
			}
{{- end }}
{{- if $f.NillableValue }}
			valueCopy := value
			return entbuilder.FieldValue{
				Spec: {{ if $f.HasValueScanner }}vv{{ else }}value{{ end }},
				Node: &valueCopy,
			}, true, nil
{{- else }}
			return entbuilder.FieldValue{
				Spec: {{ if $f.HasValueScanner }}vv{{ else }}value{{ end }},
				Node: value,
			}, true, nil
{{- end }}
		}
		return entbuilder.FieldValue{}, false, nil
	},
	Assign: func(node *{{ $.Name }}, fv entbuilder.FieldValue) error {
{{- if $f.NillableValue }}
		if v, ok := fv.Node.(*{{ $f.Type }}); ok {
			node.{{ $f.StructField }} = v
		}
{{- else }}
		node.{{ $f.StructField }} = fv.Node.({{ $f.Type }})
{{- end }}
		return nil
	},
},
{{ end }}

{{ define "dialect/sql/create/descriptor/edge" }}
{{- $e := $.Scope.Edge -}}
{
	Value: func(cfg config, m *{{ $.MutationName }}) (entbuilder.EdgeValue, bool, error) {
		nodes := m.{{ $e.StructField }}IDs()
		if len(nodes) == 0 {
			return entbuilder.EdgeValue{}, false, nil
		}
{{- with extend $ "Edge" $e "Nodes" true "Zero" "nil" }}
		{{ template "dialect/sql/defedge" . }}
{{- end }}
		return entbuilder.EdgeValue{Spec: edge, Nodes: nodes}, true, nil
	},
{{- if $e.OwnFK }}
	Assign: func(node *{{ $.Name }}, ev entbuilder.EdgeValue) error {
		ids, ok := ev.Nodes.([]{{ $e.Type.ID.Type }})
		if !ok || len(ids) == 0 {
			return nil
		}
{{- $fk := $e.ForeignKey }}
		node.{{ $fk.StructField }} = {{ if $fk.Field.NillableValue }}&{{ end }}ids[0]
		return nil
	},
{{- end }}
},
{{ end }}

{{ define "dialect/sql/create/descriptor/id" }}
{{- $id := $.ID -}}
&entbuilder.IDDescriptor[config, {{ $.Name }}, *{{ $.MutationName }}]{
	Column: {{ $.Package }}.{{ $id.Constant }},
	Type: field.{{ $id.Type.ConstName }},
	UserDefined: {{ $id.UserDefined }},
{{- if $id.UserDefined }}
	Value: func(m *{{ $.MutationName }}) (entbuilder.FieldValue, bool, error) {
		if id, ok := m.{{ $id.MutationGet }}(); ok {
{{- if and $id.Type.ValueScanner (not $id.Type.RType.IsPtr) }}
			idCopy := id
			return entbuilder.FieldValue{Spec: &idCopy, Node: id}, true, nil
{{- else }}
			return entbuilder.FieldValue{Spec: id, Node: id}, true, nil
{{- end }}
		}
		return entbuilder.FieldValue{}, false, nil
	},
	AssignNode: func(node *{{ $.Name }}, fv entbuilder.FieldValue) error {
		node.ID = fv.Node.({{ $id.Type }})
		return nil
	},
{{- end }}
	AssignGenerated: func(node *{{ $.Name }}, value driver.Value) error {
{{- if $id.Type.ValueScanner }}
		switch v := value.(type) {
		case *{{ $id.Type }}:
			if v != nil {
				node.ID = *v
				return nil
			}
		case {{ $id.Type }}:
			node.ID = v
			return nil
		}
		if err := node.ID.Scan(value); err != nil {
			return err
		}
{{- else if not $id.Type.Numeric }}
		if v, ok := value.({{ $id.Type }}); ok {
			node.ID = v
			return nil
		}
		return fmt.Errorf("unexpected {{ $.Name }}.ID type: %T", value)
{{- else }}
		switch v := value.(type) {
		case int:
			node.ID = {{ $id.Type }}(v)
		case int8:
			node.ID = {{ $id.Type }}(v)
		case int16:
			node.ID = {{ $id.Type }}(v)
		case int32:
			node.ID = {{ $id.Type }}(v)
		case int64:
			node.ID = {{ $id.Type }}(v)
		case uint:
			node.ID = {{ $id.Type }}(v)
		case uint8:
			node.ID = {{ $id.Type }}(v)
		case uint16:
			node.ID = {{ $id.Type }}(v)
		case uint32:
			node.ID = {{ $id.Type }}(v)
		case uint64:
			node.ID = {{ $id.Type }}(v)
		default:
			if v, ok := value.({{ $id.Type }}); ok {
				node.ID = v
				return nil
			}
			return fmt.Errorf("unexpected {{ $.Name }}.ID type: %T", value)
		}
{{- end }}
		return nil
	},
},
{{ end }}

{{ define "dialect/sql/create/descriptor/field" }}
{{- $f := $.Scope.Field -}}
{{- if and $f.HasValueScanner $f.NillableValue }}
entbuilder.NillableFieldWithScanner[config, {{ $.Name }}, *{{ $.MutationName }}, {{ $f.Type }}](
	{{ $.Package }}.{{ $f.Constant }},
	field.{{ $f.Type.ConstName }},
	(*{{ $.MutationName }}).{{ $f.MutationGet }},
	entbuilder.LazyScanner(func() entbuilder.ScannerFunc[{{ $f.Type }}] {
		return {{ $f.ValueFunc }}
	}),
	func(n *{{ $.Name }}, v *{{ $f.Type }}) { n.{{ $f.StructField }} = v },
),
{{- else if $f.HasValueScanner }}
entbuilder.FieldWithScanner[config, {{ $.Name }}, *{{ $.MutationName }}, {{ $f.Type }}](
	{{ $.Package }}.{{ $f.Constant }},
	field.{{ $f.Type.ConstName }},
	(*{{ $.MutationName }}).{{ $f.MutationGet }},
	entbuilder.LazyScanner(func() entbuilder.ScannerFunc[{{ $f.Type }}] {
		return {{ $f.ValueFunc }}
	}),
	func(n *{{ $.Name }}, v {{ $f.Type }}) { n.{{ $f.StructField }} = v },
),
{{- else if $f.NillableValue }}
entbuilder.NillableField[config, {{ $.Name }}, *{{ $.MutationName }}, {{ $f.Type }}](
	{{ $.Package }}.{{ $f.Constant }},
	field.{{ $f.Type.ConstName }},
	(*{{ $.MutationName }}).{{ $f.MutationGet }},
	func(n *{{ $.Name }}, v *{{ $f.Type }}) { n.{{ $f.StructField }} = v },
),
{{- else }}
entbuilder.SimpleField[config, {{ $.Name }}, *{{ $.MutationName }}, {{ $f.Type }}](
	{{ $.Package }}.{{ $f.Constant }},
	field.{{ $f.Type.ConstName }},
	(*{{ $.MutationName }}).{{ $f.MutationGet }},
	func(n *{{ $.Name }}, v {{ $f.Type }}) { n.{{ $f.StructField }} = v },
),
{{- end }}
{{ end }}

{{ define "dialect/sql/create/descriptor/edge" }}
{{- $e := $.Scope.Edge -}}
{
	Value: func(cfg config, m *{{ $.MutationName }}) (entbuilder.EdgeValue, bool, error) {
		nodes := m.{{ $e.StructField }}IDs()
		if len(nodes) == 0 {
			return entbuilder.EdgeValue{}, false, nil
		}
		edge := &sqlgraph.EdgeSpec{
			Rel:     sqlgraph.{{ $e.Rel.Type }},
			Inverse: {{ $e.IsInverse }},
			Table:   {{ $.Package }}.{{ $e.TableConstant }},
			Columns: {{ if $e.M2M }}{{ $.Package }}.{{ $e.PKConstant }}{{ else }}[]string{ {{ $.Package }}.{{ $e.ColumnConstant }} }{{ end }},
			Bidi:    {{ $e.Bidi }},
			Target: &sqlgraph.EdgeTarget{
				IDSpec: sqlgraph.NewFieldSpec({{ $e.Type.Package }}.{{ $e.Type.ID.Constant }}, field.{{ $e.Type.ID.Type.ConstName }}),
			},
		}
{{- if $.FeatureEnabled "sql/schemaconfig" }}
	{{- $schema := $e.Type.Name }}
	{{- if $e.OwnFK }}
		{{- $schema = $.Name }}
	{{- else if $e.M2M }}
		{{- if $e.Through }}
			{{- $schema = $e.Through.Name }}
		{{- else if $e.Inverse }}
			{{- $schema = print $e.Type.Name (pascal $e.Inverse) }}
		{{- else }}
			{{- $schema = print $.Name $e.StructField }}
		{{- end }}
	{{- end }}
		edge.Schema = cfg.schemaConfig.{{ $schema }}
{{- end }}
{{- with $e.Through }}
	{{- if .HasDefault }}
		// Apply through-table defaults for {{ .Name }}
		throughMut := new{{ .MutationName }}(cfg, OpCreate)
		if err := entgen.ApplyDefaults(throughMut, {{ .Package }}CreateSpec.Fields); err != nil {
			return entbuilder.EdgeValue{}, false, err
		}
		for _, fd := range {{ .Package }}CreateDescriptor.Fields {
			if fv, ok, err := fd.Value(throughMut); err != nil {
				return entbuilder.EdgeValue{}, false, err
			} else if ok {
				edge.Target.Fields = append(edge.Target.Fields, &sqlgraph.FieldSpec{
					Column: fd.Column,
					Type:   fd.Type,
					Value:  fv.Spec,
				})
			}
		}
		{{- if and .HasOneFieldID .ID.Default }}
		// Apply through-table ID default if present
		if {{ .Package }}CreateDescriptor.ID.UserDefined {
			if idFv, ok, err := {{ .Package }}CreateDescriptor.ID.Value(throughMut); err != nil {
				return entbuilder.EdgeValue{}, false, err
			} else if ok {
				edge.Target.Fields = append(edge.Target.Fields, &sqlgraph.FieldSpec{
					Column: {{ .Package }}CreateDescriptor.ID.Column,
					Type:   {{ .Package }}CreateDescriptor.ID.Type,
					Value:  idFv.Spec,
				})
			}
		}
		{{- end }}
	{{- end }}
{{- end }}
		for _, k := range nodes {
			edge.Target.Nodes = append(edge.Target.Nodes, k)
		}
		return entbuilder.EdgeValue{Spec: edge, Nodes: nodes}, true, nil
	},
{{- if $e.OwnFK }}
	Assign: func(node *{{ $.Name }}, ev entbuilder.EdgeValue) error {
		ids, ok := ev.Nodes.([]{{ $e.Type.ID.Type }})
		if !ok || len(ids) == 0 {
			return nil
		}
{{- $fk := $e.ForeignKey }}
		node.{{ $fk.StructField }} = {{ if $fk.Field.NillableValue }}&{{ end }}ids[0]
		return nil
	},
{{- end }}
},
{{ end }}

{{/* gotype: entgo.io/ent/entc/gen.Type */}}

{{ define "mutation/type" }}

{{ template "header" $ }}

import (
	"{{ $.Config.Package }}/internal"
)

{{ $n := $ }}
{{ $mutation := $n.MutationName }}

// {{ $mutation }} is an alias for the internal mutation type.
type {{ $mutation }} = internal.{{ $mutation }}

// {{ $mutation }}Option allows management of the mutation configuration using functional options.
type {{ $mutation }}Option = internal.{{ $mutation }}Option

// New{{ $mutation }} creates new mutation for the {{ $n.Name }} entity.
var New{{ $mutation }} = internal.New{{ $mutation }}

{{ with $n.HasOneFieldID }}
	var With{{ $n.Name }}ID = internal.With{{ $n.Name }}ID
	var With{{ $n.Name }} = internal.With{{ $n.Name }}
	var With{{ $n.Name }}IDsFunc = internal.With{{ $n.Name }}IDsFunc
{{ end }}

{{ end }}

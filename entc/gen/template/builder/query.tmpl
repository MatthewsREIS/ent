func ({{ $receiver }} *{{ $builder }}) prepareQuery(ctx context.Context) error {
	for _, inter := range {{ if eq $.Config.Storage.Name "sql" }}{{ $receiver }}.QueryState.Inters{{ else }}{{ $receiver }}.inters{{ end }} {
		if inter == nil {
			return fmt.Errorf("{{ $pkg }}: uninitialized interceptor (forgotten import {{ $pkg }}/runtime?)")
		}
		if trv, ok := inter.(Traverser); ok {
			if err := trv.Traverse(ctx, {{ $receiver }}); err != nil {
				return err
			}
		}
	}
	{{- /* Optional prepare checks per dialect. */}}
	{{- $tmpl = printf "dialect/%s/query/preparecheck" $.Storage }}
	{{- if hasTemplate $tmpl }}
		{{- with extend $ "Receiver" $receiver "Package" $pkg }}
			{{- xtemplate $tmpl . }}
		{{- end }}
	{{- end }}
	{{- if eq $.Config.Storage.Name "sql" }}
	if {{ $receiver }}.Path != nil {
		prev, err := {{ $receiver }}.Path(ctx)
		if err != nil {
			return err
		}
		{{ $receiver }}.Sql = prev
	}
	{{- else }}
	if {{ $receiver }}.path != nil {
		prev, err := {{ $receiver }}.path(ctx)
		if err != nil {
			return err
		}
		{{ $receiver }}.{{ $.Storage }} = prev
	}
	{{- end }}
	{{- if $.NumPolicy }}
		if {{ $.PackageQualifier }}Policy == nil {
			return errors.New("{{ $pkg }}: uninitialized {{ $.PackageQualifier }}Policy (forgotten import {{ $pkg }}/runtime?)")
		}
		if err := {{ $.PackageQualifier }}Policy.EvalQuery(ctx, {{ $receiver }}); err != nil {
			return err
		}
	{{- end }}
	return nil
}


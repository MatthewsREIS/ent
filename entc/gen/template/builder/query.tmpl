// Only returns a single {{ $.Name }} entity found by the query, ensuring it only returns one.
// Returns a *NotSingularError when more than one {{ $.Name }} entity is found.
// Returns a *NotFoundError when no {{ $.Name }} entities are found.
func ({{ $receiver }} *{{ $builder }}) Only(ctx context.Context) (*{{ $.Name }}, error) {
	{{- if eq $.Config.Storage.Name "sql" }}
	{{ $receiver }}.Limit(2)
	return entbuilder.RunOnly[*{{ $.Name }}, []*{{ $.Name }}](ctx, {{ $receiver }}, {{ $receiver }}.Ctx, ent.OpQueryOnly, {{ $.PackageQualifier }}Label, {{ $receiver }}.QueryState.Inters, {{ $receiver }}.prepareQuery, func(ctx context.Context) ([]*{{ $.Name }}, error) { return {{ $receiver }}.sqlAll(ctx) }, func(label string) error { return &NotFoundError{Label: label} }, func(label string) error { return &NotSingularError{Label: label} })
	{{- else }}
	nodes, err := {{ $receiver }}.Limit(2).All(setContextOp(ctx, {{ $receiver }}.ctx, ent.OpQueryOnly))
	if err != nil {
		return nil, err
	}
	switch len(nodes) {
	case 1:
		return nodes[0], nil
	case 0:
		return nil, &NotFoundError{Label: {{ $.PackageQualifier }}Label}
	default:
		return nil, &NotSingularError{Label: {{ $.PackageQualifier }}Label}
	}
	{{- end }}
}

// OnlyX is like Only, but panics if an error occurs.

{{/* gotype: entgo.io/ent/entc/gen.Type */}}

{{ define "facade/type" }}
{{ with extend $ "Package" (base $.Config.Package) }}
	{{ template "header" . }}
{{ end }}

{{ $n := $ }}
{{ $client := $n.ClientName }}
{{ $rec := $n.Receiver }}{{ if eq $rec "c" }}{{ $rec = printf "%.2s" $n.Name | lower }}{{ end }}
{{ $pkg := $.Package }}

import (
	{{- if $n.Edges }}
	"context"
	"database/sql/driver"
	"fmt"
	{{- end }}

	{{ $.PackageAlias }} "{{ $.Config.Package }}/{{ $.PackageDir }}"
	{{- if $n.Edges }}
	"{{ $.Config.Package }}/predicate"
	{{- $imported := dict $.PackageDir true }}
	{{- range $e := $n.Edges }}
	{{- if not (hasKey $imported $e.Type.PackageDir) }}
	{{ $e.Type.PackageAlias }} "{{ $.Config.Package }}/{{ $e.Type.PackageDir }}"
	{{- $imported = set $imported $e.Type.PackageDir true }}
	{{- end }}
	{{- end }}
	{{- end }}

	{{- if $n.Edges }}

	"entgo.io/ent/dialect/sql"
	"entgo.io/ent/dialect/sql/sqlgraph"
	{{- end }}
)

// Type aliases — public consumer-facing names continue resolving here
// while the underlying types live in the per-entity sub-package.
type (
	{{ $client }}              = {{ $.Package }}.{{ $client }}
	{{ $n.QueryName }}         = {{ $.Package }}.{{ $n.QueryName }}
	{{- if not $n.IsView }}
	{{ $n.MutationName }}      = {{ $.Package }}.{{ $n.MutationName }}
	{{ $n.CreateName }}        = {{ $.Package }}.{{ $n.CreateName }}
	{{ $n.CreateBulkName }}    = {{ $.Package }}.{{ $n.CreateBulkName }}
	{{- $noUpdate := $n.FeatureEnabled "no-update" }}
	{{- if hasKey $n.Annotations "ReadOnly" }}{{ $noUpdate = true }}{{ end }}
	{{- if not $noUpdate }}
	{{ $n.UpdateName }}        = {{ $.Package }}.{{ $n.UpdateName }}
	{{ $n.UpdateOneName }}     = {{ $.Package }}.{{ $n.UpdateOneName }}
	{{- end }}
	{{- $noDelete := $n.FeatureEnabled "no-delete" }}
	{{- if hasKey $n.Annotations "ReadOnly" }}{{ $noDelete = true }}{{ end }}
	{{- if not $noDelete }}
	{{ $n.DeleteName }}        = {{ $.Package }}.{{ $n.DeleteName }}
	{{ $n.DeleteOneName }}     = {{ $.Package }}.{{ $n.DeleteOneName }}
	{{- end }}
	{{- end }}
	{{ pascal $n.Name }}GroupBy  = {{ $.Package }}.{{ pascal $n.Name }}GroupBy
	{{ pascal $n.Name }}Select   = {{ $.Package }}.{{ pascal $n.Name }}Select
	{{- if $n.FeatureEnabled "entql" }}
	{{ $n.FilterName }}        = {{ $.Package }}.{{ $n.FilterName }}
	{{- end }}
	{{- /* Enum-field aliases — the sub-package re-exports each enum as
	       <FieldStructField> (e.g. propertylist.ReadyToCall), but consumer
	       schema/hook code historically referenced the fully-qualified
	       <NodeName><FieldStructField> form (e.g. PropertyListReadyToCall)
	       which used to live in the monolithic root pkg. Re-export them
	       here so consumers don't need a per-call import + qualifier
	       change. Skip fields with custom GoType — those resolve via their
	       declared package already. */}}
	{{- range $f := $n.EnumFields }}
	{{- if not $f.HasGoType }}
	{{- $enum := trimPackage $f.Type.String $.Package }}
	{{ $n.Name }}{{ $enum }} = {{ $.Package }}.{{ $enum }}
	{{- end }}
	{{- end }}
)

// Constructor aliases — the sub-package's New<X> stays the source of truth.
var (
	New{{ $client }} = {{ $.Package }}.New{{ $client }}
	{{- if and (not $n.IsView) ($n.FeatureEnabled "entql") }}
	New{{ $n.FilterName }}ForMutation = {{ $.Package }}.New{{ $n.FilterName }}ForMutation
	{{- end }}
)

{{- /* Cross-entity edge wiring. Sub-package *Query / *Client are leaves;
       all cross-entity references hoist here so the dependency graph
       points root → sub-packages, never the reverse. */}}
{{- range $e := $n.Edges }}
{{ $edgeQuery := $e.Type.QueryName }}
{{ $edgeClient := $e.Type.ClientName }}
{{ $func := print "With" $n.Name $e.StructField }}

// {{ $func }} eager-loads the "{{ $e.Name }}" edge on a {{ $n.QueryName }}. The
// optional arguments configure the sibling sub-query before storage.
func {{ $func }}(q *{{ $n.QueryName }}, opts ...func(*{{ $edgeQuery }})) *{{ $n.QueryName }} {
	sub := New{{ $edgeClient }}(q.Config).Query()
	for _, opt := range opts {
		opt(sub)
	}
	return q.StoreEager("{{ $e.Name }}", func(ctx context.Context, parents []*{{ $n.Name }}) error {
		return load{{ $n.Name }}{{ $e.StructField }}(ctx, sub, parents)
	})
}

{{- if and ($.FeatureEnabled "namedges") (not $e.Unique) }}
{{ $nfunc := print "WithNamed" $n.Name $e.StructField }}

// {{ $nfunc }} registers a named eager-loader for the "{{ $e.Name }}" edge on a
// {{ $n.QueryName }}. Multiple names accumulate; each loads independently and
// is retrievable via {{ $n.Name }}.Named{{ $e.StructField }}(name). Replaces the
// pre-PR6 (*{{ $n.QueryName }}).WithNamed{{ $e.StructField }} method, hoisted to root
// so the named-loader map can hold the cross-package {{ $edgeQuery }} type.
func {{ $nfunc }}(q *{{ $n.QueryName }}, name string, opts ...func(*{{ $edgeQuery }})) *{{ $n.QueryName }} {
	sub := New{{ $edgeClient }}(q.Config).Query()
	for _, opt := range opts {
		opt(sub)
	}
	return q.StoreEager("{{ $e.Name }}:"+name, func(ctx context.Context, parents []*{{ $n.Name }}) error {
		return loadNamed{{ $n.Name }}{{ $e.StructField }}(ctx, sub, parents, name)
	})
}
{{- end }}

{{ $qfunc := print "Query" $n.Name $e.StructField }}
{{ $arg := $rec }}{{ if eq $arg "id" }}{{ $arg = "node" }}{{ end }}

// {{ $qfunc }} returns a {{ $edgeQuery }} for the "{{ $e.Name }}" edge of a given {{ $n.Name }}.
func {{ $qfunc }}(c *{{ $client }}, {{ $arg }} *{{ $n.Name }}) *{{ $edgeQuery }} {
	query := New{{ $edgeClient }}(c.Config).Query()
	{{- if $n.HasOneFieldID }}
	query.Path = func(ctx context.Context) (fromV *sql.Selector, _ error) {
		{{- with extend $n "Receiver" $arg "Edge" $e "Ident" "fromV" }}
			{{- xtemplate "dialect/sql/query/from" . -}}
		{{- end }}
		return fromV, nil
	}
	{{- end }}
	return query
}

{{ $qqfunc := print "Query" $n.Name $e.StructField "FromQuery" }}

// {{ $qqfunc }} returns a {{ $edgeQuery }} that traverses the "{{ $e.Name }}" edge
// of every {{ $n.Name }} matched by q (chained-query form). Mirrors the pre-PR6
// (*{{ $n.QueryName }}).Query{{ $e.StructField }} method, hoisted to root so it
// can reference the cross-package {{ $edgeQuery }} type.
func {{ $qqfunc }}(q *{{ $n.QueryName }}) *{{ $edgeQuery }} {
	query := New{{ $edgeClient }}(q.Config).Query()
	query.Path = func(ctx context.Context) (fromV *sql.Selector, err error) {
		if err := q.PrepareQuery(ctx); err != nil {
			return nil, err
		}
		selector := q.SQLQuery(ctx)
		if err := selector.Err(); err != nil {
			return nil, err
		}
		step := sqlgraph.NewStep(
			sqlgraph.From({{ $n.Package }}.Table, {{ $n.Package }}.{{ if $n.HasCompositeID }}{{ $e.ColumnConstant }}{{ else }}{{ $n.ID.Constant }}{{ end }}, selector),
			sqlgraph.To({{ $e.Type.Package }}.Table, {{ $e.Type.Package }}.{{ if $e.Type.HasCompositeID }}{{ $e.Ref.ColumnConstant }}{{ else }}{{ $e.Type.ID.Constant }}{{ end }}),
			sqlgraph.Edge(sqlgraph.{{ $e.Rel.Type }}, {{ $e.IsInverse }}, {{ $n.Package }}.{{ $e.TableConstant }},
				{{- if $e.M2M -}}
					{{ $n.Package }}.{{ $e.PKConstant }}...
				{{- else -}}
					{{ $n.Package }}.{{ $e.ColumnConstant }}
				{{- end -}}
			),
		)
		fromV = sqlgraph.SetNeighbors(q.Drv.Dialect(), step)
		return fromV, nil
	}
	return query
}

{{ $lfunc := print "load" $n.Name $e.StructField }}

// {{ $lfunc }} performs the eager-load for the "{{ $e.Name }}" edge. Body mirrors
// the pre-PR6 *{{ $n.QueryName }}.load{{ $e.StructField }} method, hoisted to root
// so it can reference cross-package types directly.
func {{ $lfunc }}(ctx context.Context, query *{{ $edgeQuery }}, nodes []*{{ $n.Name }}) error {
	{{- if $e.M2M }}
		edgeIDs := make([]driver.Value, len(nodes))
		byID := make(map[{{ $n.ID.Type }}]*{{ $n.Name }})
		nids := make(map[{{ $e.Type.ID.Type }}]map[*{{ $n.Name }}]struct{})
		for i, node := range nodes {
			edgeIDs[i] = node.ID
			byID[node.ID] = node
			node.Edges.{{ $e.StructField }} = []*{{ $e.Type.Name }}{}
		}
		{{- /* SchemaConfig hook needs the source node ($n) so the joinT
		       schema lookup picks the correct table; the receiver here is
		       the parent query q, which has Config.SchemaConfig() in scope. */}}
		query.Where(func(s *sql.Selector) {
			joinT := sql.Table({{ $pkg }}.{{ $e.TableConstant }})
			{{- with extend $n "Builder" $n.QueryName "Edge" $e "Receiver" "query" "Ident" "joinT" "CallSet" true }}
				{{- template "dialect/sql/defedge/spec/schemaconfig" . }}
			{{- end }}
			{{- $edgeid := print $e.Type.Package "." $e.Type.ID.Constant }}
			{{- $fk1idx := 1 }}{{- $fk2idx := 0 }}{{ if $e.IsInverse }}{{ $fk1idx = 0 }}{{ $fk2idx = 1 }}{{ end }}
			s.Join(joinT).On(s.C({{ $edgeid }}), joinT.C({{ $pkg }}.{{ $e.PKConstant }}[{{ $fk1idx }}]))
			s.Where(sql.InValues(joinT.C({{ $pkg }}.{{ $e.PKConstant }}[{{ $fk2idx }}]), edgeIDs...))
			columns := s.SelectedColumns()
			s.Select(joinT.C({{ $pkg }}.{{ $e.PKConstant }}[{{ $fk2idx }}]))
			s.AppendSelect(columns...)
			s.SetDistinct(false)
		})
		if err := query.PrepareQuery(ctx); err != nil {
			return err
		}
		qr := QuerierFunc(func(ctx context.Context, q Query) (Value, error) {
			return query.Fetch(ctx, func(_ context.Context, spec *sqlgraph.QuerySpec) {
				assign := spec.Assign
				values := spec.ScanValues
				{{- $out := "sql.NullInt64" }}{{ if $n.ID.UserDefined }}{{ $out = $n.ID.ScanType }}{{ end }}
				{{- $in := "sql.NullInt64" }}{{ if $e.Type.ID.UserDefined }}{{ $in = $e.Type.ID.ScanType }}{{ end }}
				spec.ScanValues = func(columns []string) ([]any, error) {
					values, err := values(columns[1:])
					if err != nil {
						return nil, err
					}
					return append([]any{new({{ $out }})}, values...), nil
				}
				spec.Assign = func(columns []string, values []any) error {
					outValue := {{ with extend $n "Arg" "values[0]" "Field" $n.ID "ScanType" $out }}{{ template "dialect/sql/query/eagerloading/m2massign" . }}{{ end }}
					inValue := {{ with extend $n "Arg" "values[1]" "Field" $e.Type.ID "ScanType" $in }}{{ template "dialect/sql/query/eagerloading/m2massign" . }}{{ end }}
					if nids[inValue] == nil {
						nids[inValue] = map[*{{ $n.Name }}]struct{}{byID[outValue]: {}}
						return assign(columns[1:], values[1:])
					}
					nids[inValue][byID[outValue]] = struct{}{}
					return nil
				}
			})
		})
		neighbors, err := withInterceptors[[]*{{ $e.Type.Name }}](ctx, query, qr, query.QueryState.Inters)
		if err != nil {
			return err
		}
		for _, n := range neighbors {
			parents, ok := nids[n.ID]
			if !ok {
				return fmt.Errorf(`unexpected "{{ $e.Name }}" node returned %v`, n.ID)
			}
			for kn := range parents {
				kn.Edges.{{ $e.StructField }} = append(kn.Edges.{{ $e.StructField }}, n)
				{{- if and ($.FeatureEnabled "bidiedges") $e.Ref $e.Ref.Unique }}
				if !n.Edges.IsLoaded({{ $e.Ref.Index }}) {
					n.Edges.{{ $e.Ref.StructField }} = kn
				}
				{{- end }}
			}
		}
		{{- /* M2M went through Fetch (bypasses sqlAll's dispatch) to avoid
		       interceptor recursion; fire the sibling query's own
		       eager-loaders here so nested With<Sibling><Edge> calls land. */}}
		for _, loader := range query.EagerLoaders() {
			if err := loader(ctx, neighbors); err != nil {
				return err
			}
		}
	{{- else if $e.OwnFK }}
		ids := make([]{{ $e.Type.ID.Type }}, 0, len(nodes))
		nodeids := make(map[{{ $e.Type.ID.Type }}][]*{{ $n.Name }})
		for i := range nodes {
			{{- $fk := $e.ForeignKey }}
			{{- if $fk.Field.Nillable }}
				{{- if eq (pascal $fk.StructField) $fk.StructField }}
				if nodes[i].{{ $fk.StructField }} == nil {
					continue
				}
				{{- else }}
				if nodes[i].Get{{ pascal $fk.StructField }}() == nil {
					continue
				}
				{{- end }}
			{{- end }}
			{{- if eq (pascal $fk.StructField) $fk.StructField }}
			fk := {{ if $fk.Field.Nillable }}*{{ end }}nodes[i].{{ $fk.StructField }}
			{{- else }}
			fk := {{ if $fk.Field.Nillable }}*{{ end }}nodes[i].Get{{ pascal $fk.StructField }}()
			{{- end }}
			if _, ok := nodeids[fk]; !ok {
				ids = append(ids, fk)
			}
			nodeids[fk] = append(nodeids[fk], nodes[i])
		}
		if len(ids) == 0 {
			return nil
		}
		query.Where({{ $e.Type.Package }}.IDIn(ids...))
		neighbors, err := query.All(ctx)
		if err != nil {
			return err
		}
		for _, n := range neighbors {
			parents, ok := nodeids[n.ID]
			if !ok {
				{{- $fk := $e.ForeignKey }}
				return fmt.Errorf(`unexpected foreign-key "{{ $fk.Field.Name }}" returned %v`, n.ID)
			}
			for i := range parents {
				{{- if $e.Unique }}
				parents[i].Edges.{{ $e.StructField }} = n
				{{- else }}
				parents[i].Edges.{{ $e.StructField }} = append(parents[i].Edges.{{ $e.StructField }}, n)
				{{- end }}
				{{- if and ($.FeatureEnabled "bidiedges") $e.Ref $e.Ref.Unique }}
				if !n.Edges.IsLoaded({{ $e.Ref.Index }}) {
					n.Edges.{{ $e.Ref.StructField }} = parents[i]
				}
				{{- end }}
			}
		}
	{{- else }}
		fks := make([]driver.Value, 0, len(nodes))
		nodeids := make(map[{{ $n.ID.Type }}]*{{ $n.Name }})
		for i := range nodes {
			fks = append(fks, nodes[i].ID)
			nodeids[nodes[i].ID] = nodes[i]
			{{- if $e.O2M }}
				nodes[i].Edges.{{ $e.StructField }} = []*{{ $e.Type.Name }}{}
			{{- end }}
		}
		{{- /* The sibling type owns the FK column ({{ $e.ColumnConstant }} on
		       {{ $e.Type.Name }}); force its inclusion in the SELECT so the
		       per-neighbor FK lookup below has a value to read. The pre-PR6
		       method-form set query.withFKs directly; the facade-form goes
		       through the exported IncludeForeignKeys setter. */}}
		query.IncludeForeignKeys(true)
		{{- if and $e.Ref $e.Ref.Field }}
			if len(query.Ctx.Fields) > 0 {
				query.Ctx.AppendFieldOnce({{ $e.Type.Package }}.{{ $e.Ref.Field.Constant }})
			}
		{{- end }}
		query.Where(predicate.{{ $e.Type.Name }}(func(s *sql.Selector) {
			s.Where(sql.InValues(s.C({{ $pkg }}.{{ $e.ColumnConstant }}), fks...))
		}))
		neighbors, err := query.All(ctx)
		if err != nil {
			return err
		}
		for _, n := range neighbors {
			{{- $fk := $e.ForeignKey }}
			{{- if eq (pascal $fk.StructField) $fk.StructField }}
			fk := n.{{ $fk.StructField }}
			{{- else }}
			fk := n.Get{{ pascal $fk.StructField }}()
			{{- end }}
			{{- if $fk.Field.Nillable }}
				if fk == nil {
					return fmt.Errorf(`foreign-key "{{ $fk.Field.Name }}" is nil for node %v`, n.ID)
				}
			{{- end }}
			node, ok := nodeids[{{ if $fk.Field.Nillable }}*{{ end }}fk]
			if !ok {
				return fmt.Errorf(`unexpected referenced foreign-key "{{ $fk.Field.Name }}" returned %v for node %v`, {{ if $fk.Field.Nillable }}*{{ end }}fk, n{{ if $e.Type.HasOneFieldID }}.ID{{ end }})
			}
			{{- if $e.Unique }}
			node.Edges.{{ $e.StructField }} = n
			{{- else }}
			node.Edges.{{ $e.StructField }} = append(node.Edges.{{ $e.StructField }}, n)
			{{- end }}
			{{- if and ($.FeatureEnabled "bidiedges") $e.Ref $e.Ref.Unique }}
			{{- /* Inverse bidi-set: if the sibling didn't already eager-load
			       this edge explicitly, populate the back-reference so
			       consumers see a fully-resolved relationship. Mirrors the
			       pre-PR6 inline assign callback. */}}
			if !n.Edges.IsLoaded({{ $e.Ref.Index }}) {
				n.Edges.{{ $e.Ref.StructField }} = node
			}
			{{- end }}
		}
	{{- end }}
	return nil
}

{{- if and ($.FeatureEnabled "namedges") (not $e.Unique) }}
{{ $nlfunc := print "loadNamed" $n.Name $e.StructField }}

// {{ $nlfunc }} is the named-edge variant of {{ $lfunc }}. It runs the same
// neighbor-fetch logic but appends each result to the parent's
// AppendNamed{{ $e.StructField }}(name, ...) bucket instead of the default
// Edges.{{ $e.StructField }} slice. Each call seeds an empty bucket for the
// name so consumers can distinguish "loaded with zero rows" from "never
// loaded".
func {{ $nlfunc }}(ctx context.Context, query *{{ $edgeQuery }}, nodes []*{{ $n.Name }}, name string) error {
	for _, node := range nodes {
		node.AppendNamed{{ $e.StructField }}(name)
	}
	{{- if $e.M2M }}
		edgeIDs := make([]driver.Value, len(nodes))
		byID := make(map[{{ $n.ID.Type }}]*{{ $n.Name }})
		nids := make(map[{{ $e.Type.ID.Type }}]map[*{{ $n.Name }}]struct{})
		for i, node := range nodes {
			edgeIDs[i] = node.ID
			byID[node.ID] = node
		}
		query.Where(func(s *sql.Selector) {
			joinT := sql.Table({{ $pkg }}.{{ $e.TableConstant }})
			{{- with extend $n "Builder" $n.QueryName "Edge" $e "Receiver" "query" "Ident" "joinT" "CallSet" true }}
				{{- template "dialect/sql/defedge/spec/schemaconfig" . }}
			{{- end }}
			{{- $edgeid := print $e.Type.Package "." $e.Type.ID.Constant }}
			{{- $fk1idx := 1 }}{{- $fk2idx := 0 }}{{ if $e.IsInverse }}{{ $fk1idx = 0 }}{{ $fk2idx = 1 }}{{ end }}
			s.Join(joinT).On(s.C({{ $edgeid }}), joinT.C({{ $pkg }}.{{ $e.PKConstant }}[{{ $fk1idx }}]))
			s.Where(sql.InValues(joinT.C({{ $pkg }}.{{ $e.PKConstant }}[{{ $fk2idx }}]), edgeIDs...))
			columns := s.SelectedColumns()
			s.Select(joinT.C({{ $pkg }}.{{ $e.PKConstant }}[{{ $fk2idx }}]))
			s.AppendSelect(columns...)
			s.SetDistinct(false)
		})
		if err := query.PrepareQuery(ctx); err != nil {
			return err
		}
		qr := QuerierFunc(func(ctx context.Context, q Query) (Value, error) {
			return query.Fetch(ctx, func(_ context.Context, spec *sqlgraph.QuerySpec) {
				assign := spec.Assign
				values := spec.ScanValues
				{{- $out := "sql.NullInt64" }}{{ if $n.ID.UserDefined }}{{ $out = $n.ID.ScanType }}{{ end }}
				{{- $in := "sql.NullInt64" }}{{ if $e.Type.ID.UserDefined }}{{ $in = $e.Type.ID.ScanType }}{{ end }}
				spec.ScanValues = func(columns []string) ([]any, error) {
					values, err := values(columns[1:])
					if err != nil {
						return nil, err
					}
					return append([]any{new({{ $out }})}, values...), nil
				}
				spec.Assign = func(columns []string, values []any) error {
					outValue := {{ with extend $n "Arg" "values[0]" "Field" $n.ID "ScanType" $out }}{{ template "dialect/sql/query/eagerloading/m2massign" . }}{{ end }}
					inValue := {{ with extend $n "Arg" "values[1]" "Field" $e.Type.ID "ScanType" $in }}{{ template "dialect/sql/query/eagerloading/m2massign" . }}{{ end }}
					if nids[inValue] == nil {
						nids[inValue] = map[*{{ $n.Name }}]struct{}{byID[outValue]: {}}
						return assign(columns[1:], values[1:])
					}
					nids[inValue][byID[outValue]] = struct{}{}
					return nil
				}
			})
		})
		neighbors, err := withInterceptors[[]*{{ $e.Type.Name }}](ctx, query, qr, query.QueryState.Inters)
		if err != nil {
			return err
		}
		for _, n := range neighbors {
			parents, ok := nids[n.ID]
			if !ok {
				return fmt.Errorf(`unexpected "{{ $e.Name }}" node returned %v`, n.ID)
			}
			for kn := range parents {
				kn.AppendNamed{{ $e.StructField }}(name, n)
			}
		}
		for _, loader := range query.EagerLoaders() {
			if err := loader(ctx, neighbors); err != nil {
				return err
			}
		}
	{{- else if $e.OwnFK }}
		ids := make([]{{ $e.Type.ID.Type }}, 0, len(nodes))
		nodeids := make(map[{{ $e.Type.ID.Type }}][]*{{ $n.Name }})
		for i := range nodes {
			{{- $fk := $e.ForeignKey }}
			{{- if $fk.Field.Nillable }}
				{{- if eq (pascal $fk.StructField) $fk.StructField }}
				if nodes[i].{{ $fk.StructField }} == nil {
					continue
				}
				{{- else }}
				if nodes[i].Get{{ pascal $fk.StructField }}() == nil {
					continue
				}
				{{- end }}
			{{- end }}
			{{- if eq (pascal $fk.StructField) $fk.StructField }}
			fk := {{ if $fk.Field.Nillable }}*{{ end }}nodes[i].{{ $fk.StructField }}
			{{- else }}
			fk := {{ if $fk.Field.Nillable }}*{{ end }}nodes[i].Get{{ pascal $fk.StructField }}()
			{{- end }}
			if _, ok := nodeids[fk]; !ok {
				ids = append(ids, fk)
			}
			nodeids[fk] = append(nodeids[fk], nodes[i])
		}
		if len(ids) == 0 {
			return nil
		}
		query.Where({{ $e.Type.Package }}.IDIn(ids...))
		neighbors, err := query.All(ctx)
		if err != nil {
			return err
		}
		for _, n := range neighbors {
			parents, ok := nodeids[n.ID]
			if !ok {
				{{- $fk := $e.ForeignKey }}
				return fmt.Errorf(`unexpected foreign-key "{{ $fk.Field.Name }}" returned %v`, n.ID)
			}
			for i := range parents {
				parents[i].AppendNamed{{ $e.StructField }}(name, n)
			}
		}
	{{- else }}
		fks := make([]driver.Value, 0, len(nodes))
		nodeids := make(map[{{ $n.ID.Type }}]*{{ $n.Name }})
		for i := range nodes {
			fks = append(fks, nodes[i].ID)
			nodeids[nodes[i].ID] = nodes[i]
		}
		query.IncludeForeignKeys(true)
		{{- if and $e.Ref $e.Ref.Field }}
			if len(query.Ctx.Fields) > 0 {
				query.Ctx.AppendFieldOnce({{ $e.Type.Package }}.{{ $e.Ref.Field.Constant }})
			}
		{{- end }}
		query.Where(predicate.{{ $e.Type.Name }}(func(s *sql.Selector) {
			s.Where(sql.InValues(s.C({{ $pkg }}.{{ $e.ColumnConstant }}), fks...))
		}))
		neighbors, err := query.All(ctx)
		if err != nil {
			return err
		}
		for _, n := range neighbors {
			{{- $fk := $e.ForeignKey }}
			{{- if eq (pascal $fk.StructField) $fk.StructField }}
			fk := n.{{ $fk.StructField }}
			{{- else }}
			fk := n.Get{{ pascal $fk.StructField }}()
			{{- end }}
			{{- if $fk.Field.Nillable }}
				if fk == nil {
					return fmt.Errorf(`foreign-key "{{ $fk.Field.Name }}" is nil for node %v`, n.ID)
				}
			{{- end }}
			node, ok := nodeids[{{ if $fk.Field.Nillable }}*{{ end }}fk]
			if !ok {
				return fmt.Errorf(`unexpected referenced foreign-key "{{ $fk.Field.Name }}" returned %v for node %v`, {{ if $fk.Field.Nillable }}*{{ end }}fk, n{{ if $e.Type.HasOneFieldID }}.ID{{ end }})
			}
			node.AppendNamed{{ $e.StructField }}(name, n)
		}
	{{- end }}
	return nil
}
{{- end }}
{{- end }}

{{ end }}
